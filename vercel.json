{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/$1" },
    { "source": "/preview", "destination": "/public/preview.html" },
    { "source": "/((?!api/|admin/|admin$).+\\.[^/]+)", "destination": "/public/$1" },
    { "source": "/((?!api/|admin/|admin$).*)", "destination": "/public/index.html" }
  ]
}
